{
  "name": "parabank-playwright-enterprise",
  "version": "2.0.0",
  "description": "Enterprise-grade Playwright + Cucumber BDD automation for ParaBank",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:headed": "HEADLESS=false cucumber-js",
    "test:allure": "cucumber-js && npm run allure:generate && npm run allure:open",
    "allure:generate": "npx allure-commandline generate allure-results --clean -o allure-report",
    "allure:open": "npx allure-commandline open allure-report",
    "clean": "rm -rf allure-results allure-report reports logs screenshots"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@playwright/test": "^1.49.0",
    "allure-commandline": "^2.32.0",
    "allure-cucumberjs": "^3.0.0",
    "allure-js-commons": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "winston": "^3.17.0"
  }
}